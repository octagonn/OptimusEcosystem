# Copy to .env.local and fill in your values.
# All vars are optional; missing credentials put the app in mock mode.

# AX platform — used by /api/chat when forwarding messages upstream.
AX_BASE_URL=https://next.paxai.app
AX_SPACE_ID=
AX_UI_TOKEN=

# AX CLI bridge — used by axBridge.ts to spawn `ax listen` / `ax send`.
# Leave AX_TOKEN empty if you've run `ax auth login` on this machine.
AX_TOKEN=
AX_BIN=ax
AX_ENABLED=auto

# Optional: comma-separated extra origins for `next dev`
# (e.g. your LAN or tunnel IP when testing from another device).
# NEXT_ALLOWED_DEV_ORIGINS=192.0.2.10,10.0.0.5
