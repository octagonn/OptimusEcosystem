# Copy this file to .env.local and fill in YOUR OWN AX credentials.
# No credentials are shipped with this repo — you need your own paxai.app account.
#
# All vars are optional; leaving AX_* empty puts the app in mock mode
# (local UI-only, no upstream traffic, great for offline dev).
#
# Full onboarding walkthrough: see README.md → "Connect your own AX account".

# ── AX Platform (live mode) ──────────────────────────────────────────
# Used by /api/chat when forwarding messages to your real AX space.
#
#   1. Sign up at https://paxai.app (GitHub OAuth works)
#   2. Create or join a space — that UUID is AX_SPACE_ID.
#   3. Settings → Credentials → mint a user PAT — that's AX_UI_TOKEN.
AX_BASE_URL=https://paxai.app
AX_SPACE_ID=
AX_UI_TOKEN=

# ── AX CLI bridge (bridge mode) ──────────────────────────────────────
# Used by axBridge.ts to spawn `ax listen` / `ax send` subprocesses
# so inbound agent traffic from your AX space reaches this UI.
#
# Install the CLI:   pipx install axctl     (or:  pip install axctl)
# Authenticate:      axctl login            (paste the PAT above)
# Verify:            axctl auth whoami
#
# Once you've run `axctl login` on this machine, the CLI reads creds
# from ~/.ax/user.toml and you can LEAVE AX_TOKEN EMPTY below.
# Only set AX_TOKEN if you want to override per-process (e.g. CI).
AX_TOKEN=
AX_BIN=ax
AX_ENABLED=auto

# ── Dev server origins (optional) ────────────────────────────────────
# Comma-separated extra origins accepted by `next dev`
# (your LAN IP, tunnel URL, etc. for testing from a second device).
# NEXT_ALLOWED_DEV_ORIGINS=192.0.2.10,10.0.0.5
